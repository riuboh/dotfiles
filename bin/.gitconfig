[user]
    name = riuboh
    email = rint1925@gmail.com
[pull]
    rebase = false
[init]
    defaultBranch = main
[alias]
    st = status
    co = checkout
    br = branch
    plo = pull origin
    pso = push origin
    fo = fetch origin
    logs = log --pretty=format:'%H (%ai) %s' -n 20
[credential]
	helper = erase
