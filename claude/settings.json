{
  "permissions": {
    "allow": [
      "mcp__plugin_discord_discord__reply",
      "Fetch",
      "Grep",
      "Read",
      "Skill",
      "WebFetch",
      "WebSearch"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.sh 'Claude Code' '入力が求められています' 'Blow'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.sh 'Claude Code' '作業が完了しました' 'Glass'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "discord@claude-plugins-official": true
  },
  "effortLevel": "medium",
  "model": "opus"
}
